{
  "name": "powo",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22 <23",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "npm run build && npm run start",
    "lint": "eslint",
    "test": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/normalize-health-export.test.mts && node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/consistency.test.mts && node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/insights.test.mts",
    "test:consistency": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/consistency.test.mts",
    "test:insights": "node --experimental-strip-types --disable-warning=MODULE_TYPELESS_PACKAGE_JSON scripts/insights.test.mts",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev",
    "verify": "npm run lint && npm run test && npm run typecheck && npm run build",
    "smoke": "node scripts/smoke-production.mjs",
    "smoke:build": "npm run build && npm run smoke",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "qa": "npm run verify && npm run audit:prod && npm run smoke"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "framer-motion": "^12.38.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.14"
    }
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2",
    "lightningcss-linux-x64-gnu": "1.32.0"
  }
}
